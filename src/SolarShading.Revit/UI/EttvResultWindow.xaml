<Window x:Class="SolarShading.Revit.UI.EttvResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ETTV Results" Height="420" Width="520"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Per-orientation envelope breakdown" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1" x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Orientation" Binding="{Binding Orientation}" Width="*"/>
                <DataGridTextColumn Header="Window m²" Binding="{Binding WindowAreaM2, StringFormat=N1}" Width="*"/>
                <DataGridTextColumn Header="WWR %" Binding="{Binding WwrPercent, StringFormat=N0}" Width="*"/>
                <DataGridTextColumn Header="SC2" Binding="{Binding Sc2, StringFormat=N2}" Width="*"/>
                <DataGridTextColumn Header="ETTV W/m²" Binding="{Binding Ettv, StringFormat=N1}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" x:Name="SummaryBorder" Margin="0,12,0,0" Padding="10" CornerRadius="4">
            <TextBlock x:Name="SummaryText" FontWeight="Bold" FontSize="14" Foreground="White"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Width="90" Height="28" IsDefault="True" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
